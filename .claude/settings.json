{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gate-canonical-docs.js",
            "shell": "bash",
            "timeout": 10,
            "statusMessage": "Checking canonical-doc guardrails..."
          }
        ]
      }
    ]
  }
}
