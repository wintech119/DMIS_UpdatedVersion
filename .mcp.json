{
  "mcpServers": {
    "angular": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"],
      "env": {}
    },
    "snyk": {
      "command": "npx",
      "args": ["-y", "snyk@latest", "mcp", "-t", "stdio"],
      "env": {}
    },
    "django-ai-boost": {
      "command": "./scripts/run_django_mcp.cmd",
      "args": [],
      "env": {}
    },
    "postgres": {
      "command": "uvx",
      "args": ["postgres-mcp", "--access-mode=unrestricted"],
      "env": {
        "DATABASE_URI": "postgresql://postgres:YOUR_PASSWORD@localhost:5432/dmis"
      }
    }
  }
}
