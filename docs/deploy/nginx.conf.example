# DMIS NGINX example for the Angular + Django stack
#
# This example assumes:
# - Angular static assets are deployed to /var/www/dmis/browser
# - Gunicorn serves Django on 127.0.0.1:8000 with:
#     gunicorn dmis_api.wsgi:application --bind 127.0.0.1:8000 --workers 4
# - TLS terminates at NGINX and NGINX forwards X-Forwarded-Proto to Django
#
# Render this example with deployment tooling or replace these placeholders
# directly before use:
# - HSTS_SECONDS
# - HSTS_INCLUDE_SUBDOMAINS
# - HSTS_PRELOAD
#
# Per-environment values:
# - shared-dev: HSTS_SECONDS=3600, HSTS_INCLUDE_SUBDOMAINS=, HSTS_PRELOAD=
# - staging: HSTS_SECONDS=86400, HSTS_INCLUDE_SUBDOMAINS=, HSTS_PRELOAD=
# - production (default): HSTS_SECONDS=31536000,
#   HSTS_INCLUDE_SUBDOMAINS="; includeSubDomains", HSTS_PRELOAD=
# - production (preload opt-in only): HSTS_SECONDS=31536000,
#   HSTS_INCLUDE_SUBDOMAINS="; includeSubDomains",
#   HSTS_PRELOAD="; preload"
#
# Rendered header examples:
# - shared-dev: max-age=3600
# - staging: max-age=86400
# - production (default): max-age=31536000; includeSubDomains
# - production (preload opt-in only):
#   max-age=31536000; includeSubDomains; preload

upstream dmis_django {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name dmis.example.org;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name dmis.example.org;

    ssl_certificate /etc/letsencrypt/live/dmis.example.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dmis.example.org/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;
    ssl_protocols TLSv1.2 TLSv1.3;

    root /var/www/dmis/browser;
    index index.html;

    server_tokens off;
    client_max_body_size 16m;

    # Match these edge headers to the runtime profile selected by DMIS_RUNTIME_ENV.
    add_header Strict-Transport-Security "max-age=${HSTS_SECONDS}${HSTS_INCLUDE_SUBDOMAINS}${HSTS_PRELOAD}" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;

    location /api/ {
        proxy_pass http://dmis_django;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 120s;
        proxy_send_timeout 60s;
        proxy_connect_timeout 60s;
    }

    location /static/ {
        alias /var/www/dmis/static/;
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
}
