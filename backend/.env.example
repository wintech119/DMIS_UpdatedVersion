# Copy to .env and set your real values. Do not commit .env.
# Required runtime posture selection:
# - local harness: use backend/.env.local.example with DMIS_RUNTIME_ENV=local-harness
# - prod-like local smoke test: set DMIS_RUNTIME_ENV=prod-like-local and DMIS_SKIP_LOCAL_ENV=1
# - shared dev / staging / production: set DMIS_RUNTIME_ENV=shared-dev|staging|production
DMIS_RUNTIME_ENV=prod-like-local

# Database (PostgreSQL)
DB_NAME=dmis
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# PostgreSQL-first runtime (recommended)
DJANGO_USE_SQLITE=0

# Emergency-only local SQLite override (disabled by default)
# DJANGO_USE_SQLITE=1
# DJANGO_ALLOW_SQLITE=1

# Redis cache (optional in dev — falls back to in-memory if unset)
# REDIS_URL=redis://localhost:6379/1
# RUNNING_TESTS=1
# TEST_REDIS_CACHE_ENABLED=1

# Django runtime posture
# - prod-like-local must set DJANGO_SECRET_KEY and DJANGO_ALLOWED_HOSTS explicitly
# - shared-dev, staging, and production fail closed unless the secure deployment posture
#   matches the declared DMIS_RUNTIME_ENV
# DJANGO_SECRET_KEY=replace-with-a-real-secret
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_DEBUG=0
#
# Optional overrides for prod-like-local. Shared-dev/staging/production already default to
# secure values and should only override these when intentionally matching their runtime profile.
# DJANGO_SECURE_SSL_REDIRECT=0
# DJANGO_SESSION_COOKIE_SECURE=0
# DJANGO_CSRF_COOKIE_SECURE=0
# DJANGO_SECURE_HSTS_SECONDS=0
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
# DJANGO_SECURE_HSTS_PRELOAD=0
# DJANGO_X_FRAME_OPTIONS=DENY
# DJANGO_SECURE_REFERRER_POLICY=same-origin
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.dmis.example.org
#
# Non-local defaults by runtime environment:
# - shared-dev: HSTS 3600 seconds, no subdomain include, no preload
# - staging: HSTS 86400 seconds, no subdomain include, no preload
# - production: HSTS 31536000 seconds, includeSubDomains=1, preload opt-in only
#
# Shared-dev/staging/production assume a trusted TLS-terminating reverse proxy that forwards:
#   X-Forwarded-Proto: https
#
# Non-local auth baseline. Shared dev, staging, production, and prod-like-local
# should all stay on real auth only.
# AUTH_ENABLED=1
# DEV_AUTH_ENABLED=0
# LOCAL_AUTH_HARNESS_ENABLED=0
# Local-only auth bypass. Use only with DMIS_RUNTIME_ENV=local-harness and DJANGO_DEBUG=1.
# DEV_AUTH_ENABLED=1
# TEST_DEV_AUTH_ENABLED=1
# LOCAL_AUTH_HARNESS_ENABLED=1
# DMIS_SKIP_LOCAL_ENV=1
# Enable strict tenant-scoped filtering/enforcement across workflow APIs.
# Set to 1 only after tenant_user/warehouse mappings are aligned.
# TENANT_SCOPE_ENFORCEMENT=0

# Tenant codes allowed to manage event phase demand/planning windows.
# Intended for ODPEM and ODPEM-NEOC only.
# NATIONAL_PHASE_WINDOW_ADMIN_CODES=OFFICE-OF-DISASTER-P,ODPEM-NEOC

# IFRC Item Code Assistant
# IFRC_ENABLED=1
# IFRC_LLM_ENABLED=0
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL_ID=qwen3.5:0.8b
# OLLAMA_TIMEOUT_SECONDS=10
# IFRC_AUTO_FILL_THRESHOLD=0.80
# IFRC_MIN_INPUT_LENGTH=3
# IFRC_MAX_INPUT_LENGTH=120
# IFRC_CB_FAILURE_THRESHOLD=5
# IFRC_CB_RESET_TIMEOUT=120
# IFRC_RATE_LIMIT_PER_MINUTE=30
