# Copy to .env and set your real values. Do not commit .env.
# Database (PostgreSQL)
DB_NAME=dmis
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# PostgreSQL-first runtime (recommended)
DJANGO_USE_SQLITE=0

# Emergency-only local SQLite override (disabled by default)
# DJANGO_USE_SQLITE=1
# DJANGO_ALLOW_SQLITE=1

# Optional: Django
# DJANGO_SECRET_KEY=your-secret-key
# DJANGO_DEBUG=1
# DEV_AUTH_ENABLED=1
# Enable strict tenant-scoped filtering/enforcement across workflow APIs.
# Set to 1 only after tenant_user/warehouse mappings are aligned.
# TENANT_SCOPE_ENFORCEMENT=0

# Tenant codes allowed to manage event phase demand/planning windows.
# Intended for ODPEM and ODPEM-NEOC only.
# NATIONAL_PHASE_WINDOW_ADMIN_CODES=OFFICE-OF-DISASTER-P,ODPEM-NEOC
