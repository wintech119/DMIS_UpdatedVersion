# Optional local development overrides.
# Copy to .env.local for debug/local-harness startup on this machine only.
# This file is loaded automatically for runserver/shell, or when
# DMIS_LOAD_LOCAL_ENV=1 is set in the process environment.
#
# Do not use this file for prod-like-local, shared-dev, staging, or production.
# The default harness posture uses a local Redis instance. Unset REDIS_URL only
# if you intentionally want the explicit local-only degraded cache mode.
# Async exports run inline by default in local-harness. Set DMIS_ASYNC_EAGER=0 only
# if you also plan to run a local Celery worker process.

DMIS_RUNTIME_ENV=local-harness
DJANGO_DEBUG=1
REDIS_URL=redis://localhost:6379/1
DMIS_ASYNC_EAGER=1
AUTH_ENABLED=0
DEV_AUTH_ENABLED=1
TEST_DEV_AUTH_ENABLED=1
LOCAL_AUTH_HARNESS_ENABLED=1
DEV_AUTH_USER_ID=local_system_admin_tst
LOCAL_AUTH_HARNESS_USERNAMES=local_system_admin_tst,local_odpem_deputy_director_tst,local_odpem_logistics_manager_tst,local_odpem_logistics_officer_tst,relief_jrc_requester_tst
DEV_AUTH_ROLES=SYSTEM_ADMINISTRATOR
DEV_AUTH_PERMISSIONS=
TENANT_SCOPE_ENFORCEMENT=1
